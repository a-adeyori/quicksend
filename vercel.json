{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci && npx expo export -p web",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/:path((?!_expo|.*\\..*).*)",
      "destination": "/:path.html"
    }
  ]
}
