// QuickSend Database Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @unique
  firstName    String
  lastName     String
  passwordHash String
  role         UserRole @default(USER)

  // ILP wallet info
  walletAddress String? @unique // their Open Payments wallet URL (external wallet)
  ilpAccountId  String? @unique // internal Rafiki account ID (if hosted on your Rafiki)

  // App state
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  kycStatus     KYCStatus @default(PENDING)
  kycVerifiedAt DateTime?

  // Balance mirror (kept in sync with Rafiki via webhooks)
  // Stored in the smallest asset unit (cents for USD, i.e. scale=2)
  balanceCents BigInt @default(0)
  assetCode    String @default("USD")
  assetScale   Int    @default(2)

  // Relations
  outgoingPayments Payment[]      @relation("SenderPayments")
  incomingPayments Payment[]      @relation("ReceiverPayments")
  contacts         Contact[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  notifications    Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([walletAddress])
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  initials      String
  color         String  @default("#D1FAE5")
  walletAddress String // Open Payments URL of the contact
  phone         String?
  email         String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, walletAddress])
  @@index([userId])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id String @id @default(uuid())

  // Parties
  senderId   String
  sender     User    @relation("SenderPayments", fields: [senderId], references: [id])
  receiverId String?
  receiver   User?   @relation("ReceiverPayments", fields: [receiverId], references: [id])

  // Recipient info (for external wallets where receiverId is null)
  recipientWalletAddress String
  recipientName          String

  // Amounts (in smallest unit, e.g. cents)
  debitAmountCents   BigInt
  receiveAmountCents BigInt
  feeAmountCents     BigInt @default(0)
  assetCode          String @default("USD")
  assetScale         Int    @default(2)

  // ILP references
  ilpQuoteId           String? @unique
  ilpOutgoingPaymentId String? @unique
  ilpIncomingPaymentId String?

  // State machine
  status     PaymentStatus @default(PENDING)
  failReason String?

  // Metadata
  note      String?
  reference String? @unique @default(cuid())

  // Timestamps
  initiatedAt DateTime  @default(now())
  processedAt DateTime?
  completedAt DateTime?
  failedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([ilpOutgoingPaymentId])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING // Created, not yet submitted to ILP
  QUOTING // Fetching ILP quote
  QUOTED // Quote obtained, awaiting user confirmation
  PROCESSING // Submitted to ILP, awaiting completion
  COMPLETED // ILP payment completed
  FAILED // ILP payment failed
  CANCELLED // Cancelled by user before processing
  REVERSED // Successfully reversed/refunded
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(uuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id     String           @id @default(uuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

enum NotificationType {
  PAYMENT_SENT
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  ACCOUNT_VERIFIED
  SECURITY_ALERT
  SYSTEM
}

// ─── ILP Webhook Events ───────────────────────────────────────────────────────

model WebhookEvent {
  id          String             @id @default(uuid())
  eventType   String
  payload     Json
  status      WebhookEventStatus @default(PENDING)
  processedAt DateTime?
  error       String?
  retries     Int                @default(0)

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([status])
}

enum WebhookEventStatus {
  PENDING
  PROCESSED
  FAILED
  IGNORED
}
