# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ─── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
DATABASE_URL="postgresql://quicksend:quicksend_pass@localhost:5432/quicksend_db?schema=public"

# ─── Redis (BullMQ queues + caching) ─────────────────────────────────────────
REDIS_URL="redis://:redis_pass@localhost:6379"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="another-long-random-secret-for-refresh-tokens"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Rafiki / ILP ─────────────────────────────────────────────────────────────
# Your Rafiki instance URLs
RAFIKI_AUTH_SERVER_URL="https://auth.interledger-test.dev/f537937b-7016-481b-b655-9f0d1014822c"
RAFIKI_RESOURCE_SERVER_URL="https://ilp.interledger-test.dev/f537937b-7016-481b-b655-9f0d1014822c"

# The wallet address that backs the QuickSend platform account
# All user funds flow through this account and are tracked in your DB
QUICKSEND_PLATFORM_WALLET_ADDRESS="https://ilp.interledger-test.dev/quicksend"

# Service-level GNAP token for the platform wallet (long-lived, kept server-side)
# Generate this by running: npm run scripts:grant
RAFIKI_SERVICE_TOKEN=""

# Webhook secret for validating Rafiki event callbacks
RAFIKI_WEBHOOK_SECRET="change-me-in-production"

# ─── Interledger Testnet (for local dev without a self-hosted Rafiki) ─────────
# Sign up at https://www.interledger.org/developers/get-started
# ILF_WALLET_ADDRESS="https://ilp.interledger-test.dev/your-account"
# ILF_WALLET_SECRET="your-secret-key"

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_SEND_MAX=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:8081,http://localhost:3000,https://your-app.com"

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Email (for notifications) ────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@quicksend.app
SMTP_PASS=your-smtp-password
