# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ─── JSON file store (Vercel / demos — no PostgreSQL) ──────────────────────────
# Set to true to use a single JSON document (local file or Vercel KV) instead of Prisma.
# Vercel: add Redis/KV from the marketplace and set KV_REST_API_URL (and token env vars it provides).
USE_JSON_DB=false

# ─── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
# Omit when USE_JSON_DB=true
DATABASE_URL="postgresql://quicksend:quicksend_pass@localhost:5432/quicksend_db?schema=public"

# ─── Redis (BullMQ queues + caching) ─────────────────────────────────────────
REDIS_URL="redis://:redis_pass@localhost:6379"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET="MH3SRbNpxrmTQUuj4Ye5kgGq69K7ALBlDXVc08tEiCaPdJv1OZIWznwohy2Fsf"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="RKLbHGOsf5Np1ZmnWljAQo7qcaMB8D9T3g46IFiyCxwe0z2EvuUVPShkrdtXYJ"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Rafiki / ILP ─────────────────────────────────────────────────────────────
# Your Rafiki instance URLs
RAFIKI_AUTH_SERVER_URL="https://auth.interledger-test.dev/f537937b-7016-481b-b655-9f0d1014822c"
RAFIKI_RESOURCE_SERVER_URL="https://ilp.interledger-test.dev/f537937b-7016-481b-b655-9f0d1014822c"

# The wallet address that backs the QuickSend platform account
# All user funds flow through this account and are tracked in your DB
QUICKSEND_PLATFORM_WALLET_ADDRESS="https://ilp.interledger-test.dev/quicksend"

# Service-level GNAP token for the platform wallet (long-lived, kept server-side)
# Generate this by running: npm run scripts:grant
RAFIKI_SERVICE_TOKEN=""

# Webhook secret for validating Rafiki event callbacks
RAFIKI_WEBHOOK_SECRET="JPS8EWN9xnjTVils510Htq4CpGbc6eORLI3XwmBM"

# Rafiki Backend Admin API (tenant-scoped) — required for /wallet/create-address and auto wallet creation on register
# Example endpoint: https://rafiki-admin.yourdomain.com/graphql
RAFIKI_ADMIN_API_URL=""
RAFIKI_TENANT_ID=""
RAFIKI_TENANT_API_SECRET=""
# Asset ID from Rafiki Admin (GraphQL). Wallet addresses are created under this asset.
RAFIKI_WALLET_ASSET_ID=""

# ─── Interledger Testnet (for local dev without a self-hosted Rafiki) ─────────
# Sign up at https://www.interledger.org/developers/get-started
# ILF_WALLET_ADDRESS="https://ilp.interledger-test.dev/your-account"
# ILF_WALLET_SECRET="your-secret-key"

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_SEND_MAX=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated browser origins (no trailing slash). For judge laptops + Expo web: add http://YOUR_LAN_IP:8081
# (same host as EXPO_PUBLIC_API_URL in repo root `.env`, port 8081 for Metro web).
CORS_ORIGINS="http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://localhost:3000,https://your-app.com"

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Email (for notifications) ────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@quicksend.app
SMTP_PASS=your-smtp-password
