# ─── Interactive demo (recommended for Expo Go & sharing) ─────────────────────
# Set to true: no backend required, no real money, full UI + simulated voice flow.
EXPO_PUBLIC_DEMO_MODE=true

# ─── Live API (when EXPO_PUBLIC_DEMO_MODE is not true) ───────────────────────
EXPO_PUBLIC_API_URL=http://YOUR_HOST:3001/api/v1

# Rafiki / Open Payments (mobile client — optional for live mode)
EXPO_PUBLIC_RAFIKI_AUTH_URL=https://auth.example.com
EXPO_PUBLIC_RAFIKI_RESOURCE_URL=https://wallet.example.com
EXPO_PUBLIC_CLIENT_WALLET_ADDRESS=https://wallet.example.com/your-address
