# ─── Web + iOS Safari: use HTTPS in production so mic + secure storage work ─

# ─── Reviewer / submission (live API + seeded demo@quicksend.app) ─────────────────
# EXPO_PUBLIC_FRONTEND_ONLY=false
# EXPO_PUBLIC_USE_LIVE_AUTH=true
# EXPO_PUBLIC_API_URL=https://YOUR-API-HOST/api/v1
# Then: backend → prisma migrate deploy && prisma db seed  (see REVIEWER.md)

# Pure client app (no API): welcome → demo login, wallet saved in localStorage / MMKV.
# Default true so Vercel / new clones work without a reachable API (see src/config/demo.ts).
EXPO_PUBLIC_FRONTEND_ONLY=true

# Simulated wallet (fake balance / local send simulation) when true.
EXPO_PUBLIC_DEMO_MODE=true

# Real JWT sign-up / sign-in via EXPO_PUBLIC_API_URL (passwords hashed on server; tokens in SecureStore).
# - Automatically ON when EXPO_PUBLIC_DEMO_MODE=false (full production).
# - When DEMO_MODE=true, set this true to get secure accounts + demo wallet + ILP token in Settings.
EXPO_PUBLIC_USE_LIVE_AUTH=false

# Backend API — required when EXPO_PUBLIC_USE_LIVE_AUTH=true or EXPO_PUBLIC_DEMO_MODE=false
# Example: https://api.yourdomain.com/api/v1
# Judge laptops on your Wi‑Fi: use your PC’s LAN IP (not localhost), e.g. http://192.168.1.10:3001/api/v1
# Run: npm run web:lan — judges open http://YOUR_LAN_IP:8081 in Chrome/Edge/Safari.
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Interledger / Open Payments (client-side discovery + Settings; align with backend RAFIKI_*)
EXPO_PUBLIC_RAFIKI_AUTH_URL=https://auth.interledger-test.dev/your-tenant-id
EXPO_PUBLIC_RAFIKI_RESOURCE_URL=https://ilp.interledger-test.dev/your-tenant-id
EXPO_PUBLIC_CLIENT_WALLET_ADDRESS=https://ilp.interledger-test.dev/quicksend

# Server-only secrets stay in backend/.env (never EXPO_PUBLIC_*):
# JWT_*, DATABASE_URL, RAFIKI_SERVICE_TOKEN, RAFIKI_WEBHOOK_SECRET, etc.

# ─── Production web (HTTPS + CORS) ───────────────────────────────────────────────
# Full production: EXPO_PUBLIC_DEMO_MODE=false (implies live auth + live wallet API).
# Build: npm run export:web — host over HTTPS; backend CORS_ORIGINS = your web origin.
